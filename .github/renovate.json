{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "schedule": ["on sunday"],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions dependencies"
    },
    {
      "matchManagers": ["gradle"],
      "enabled": true
    },
    {
      "matchPackageNames": ["org.jetbrains.kotlin/**", "org.jetbrains.kotlinx/**"],
      "groupName": "Kotlin dependencies"
    },
    {
      "matchPackageNames": ["com.squareup.okhttp3/**"],
      "groupName": "OkHttp dependencies"
    },
    {
      "matchPackageNames": ["org.jsoup:jsoup"],
      "groupName": "Jsoup dependencies"
    },
    {
      "matchPackageNames": [
        "com.android.tools.build:gradle",
        "gradle"
      ],
      "groupName": "Android Gradle Plugin & Gradle Wrapper",
      "draftPR": true
    }
  ]
}
